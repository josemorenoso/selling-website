    {
      "parameters": {
        "jsCode": "// 1. Extraemos el mensaje de forma segura\nconst msg = $json.message || $json.edited_message || {};\n\n// 2. Usamos Optional Chaining (?.) para que si no existe el dato, devuelva null en vez de error\nconst hasVoice = msg.voice ? true : false;\nconst hasText = msg.text ? true : false;\n\n// 3. Verificamos que al menos existan los datos básicos del chat/usuario\nif (!msg.chat || !msg.from) {\n    return [{\n        json: {\n            error: \"Mensaje de sistema o vacío detectado\",\n            messageType: 'other'\n        }\n    }];\n}\n\n// 4. Detectar comando de reset/clear\nconst text = (msg.text || '').toLowerCase().trim();\nconst resetCommands = ['clear', 'reset', 'reiniciar', 'limpiar', 'nueva conversacion', 'nueva conversación', 'empezar de nuevo', 'start over', 'borrar'];\nconst isResetCommand = resetCommands.includes(text);\n\nreturn [{\n  json: {\n    sessionId: `telegram_${msg.chat.id}`,\n    userId: msg.from.id,\n    userName: `${msg.from.first_name || ''} ${msg.from.last_name || ''}`.trim(),\n    chatId: msg.chat.id,\n    messageId: msg.message_id,\n    messageType: hasVoice ? 'voice' : (hasText ? 'text' : 'other'),\n    rawVoiceFileId: msg.voice?.file_id || null,\n    rawText: msg.text || null,\n    isResetCommand: isResetCommand,\n    timestamp: new Date().toISOString()\n  }\n}];"
      },
